# ============================================================
# COPIA ESTE ARCHIVO A .env Y RELLENA TODOS LOS VALORES
# cp .env.example .env
#
# O ejecuta: bash scripts/setup.sh  (genera credenciales automáticamente)
#
# Generar claves manualmente:
#   N8N_ENCRYPTION_KEY:  openssl rand -hex 32
#   POSTGRES_PASSWORD:   openssl rand -base64 24 | tr -d '/+=' | head -c 24
#   REDIS_PASSWORD:      openssl rand -base64 24 | tr -d '/+=' | head -c 24
#   MINIO_ROOT_PASSWORD: openssl rand -base64 24 | tr -d '/+=' | head -c 24
# ============================================================

# ---- Dominios -----------------------------------------------
N8N_HOST=n8n.tudominio.com
MINIO_DOMAIN=minio.tudominio.com
MINIO_CONSOLE_DOMAIN=minio-console.tudominio.com

# ---- Red overlay de Traefik ---------------------------------
# Debe coincidir con la red donde está el servicio traefik
TRAEFIK_NETWORK=traefik-public

# ---- PostgreSQL ---------------------------------------------
POSTGRES_PASSWORD=CAMBIA_ESTO

# ---- Redis --------------------------------------------------
REDIS_PASSWORD=CAMBIA_ESTO

# ---- n8n ----------------------------------------------------
# DEBE SER IGUAL en main, webhook y los 3 workers
# Generada UNA VEZ — cambiarla después rompe todas las credenciales cifradas
N8N_ENCRYPTION_KEY=CAMBIA_ESTO_usa_openssl_rand_hex_32

# ---- MinIO --------------------------------------------------
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=CAMBIA_ESTO
